# ============================================================
# PRONTUÁRIO ELETRÔNICO — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# ── Banco de Dados (MySQL 8+ / MariaDB 10.6+ / TiDB / PlanetScale) ──────────
# Formato: mysql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL=mysql://root:senha@localhost:3306/prontuario_eletronico

# ── Segredo JWT (cookie de sessão) ───────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=substitua_por_uma_string_aleatoria_longa_e_segura_aqui

# ── Título da aplicação (aparece na aba do browser) ─────────────────────────
VITE_APP_TITLE=Prontuário Eletrônico

# ── Porta do servidor (padrão: 3000) ────────────────────────────────────────
PORT=3000

# ── OAuth Manus (necessário APENAS se rodar dentro do Manus) ────────────────
# Se estiver rodando fora do Manus, consulte o README.md para substituir
# o sistema de autenticação por login local (usuario/senha).
VITE_APP_ID=
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://manus.im
OWNER_OPEN_ID=
OWNER_NAME=

# ── APIs internas Manus (nao necessarias fora do Manus) ─────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_APP_LOGO=

# ── Analytics (opcional — remova se nao usar) ────────────────────────────────
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
